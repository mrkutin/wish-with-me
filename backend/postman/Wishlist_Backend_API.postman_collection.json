                  "    pm.expect(item).to.have.property('title', 'Product Name');",
                  "    pm.expect(item).to.have.property('price', 99.99);",
                  "    pm.expect(item).to.have.property('currency', 'USD');",
                  "    pm.expect(item).to.have.property('addedAt').that.is.a('string');",
                  "});",
                  "",
                  "console.log('Saved itemId:', item._id);"
                ]
