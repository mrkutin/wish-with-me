                  "    pm.expect(wishlist).to.have.property('items').that.is.an('array');",
                  "    pm.expect(wishlist).to.have.property('sharedWith').that.is.an('array');",
                  "    pm.expect(wishlist).to.have.property('createdAt');",
                  "    pm.expect(wishlist).to.have.property('updatedAt');",
                  "});",
