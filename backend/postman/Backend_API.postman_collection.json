{
  "info": {
    "_postman_id": "your-collection-id",
    "name": "Backend API",
    "description": "Collection for testing the Node.js backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Check if the API and database are healthy"
      },
      "response": []
    },
    {
      "name": "Create Test Document",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"message\": \"Hello, CouchDB!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/test",
          "host": ["{{baseUrl}}"],
          "path": ["test"]
        },
        "description": "Create a new test document in CouchDB"
      },
      "response": []
    },
    {
      "name": "Get Test Document",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/test/{{documentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["test", "{{documentId}}"]
        },
        "description": "Retrieve a test document by ID"
      },
      "response": []
    }
  ],
  "event": [],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "",
      "type": "string",
      "description": "ID of the created document"
    }
  ]
} 