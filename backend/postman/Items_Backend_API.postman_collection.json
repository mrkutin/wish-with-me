          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Item\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/wishlists/{{wishlistId}}/items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "wishlists",
                "{{wishlistId}}",
                "items"
              ]
            },
            "description": "Add item with name only"
          },
          "response": []
