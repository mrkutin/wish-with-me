        {
          "name": "Add Item with Name",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('itemId', jsonData._id);",
                  "}"
                ]
              }
            }
